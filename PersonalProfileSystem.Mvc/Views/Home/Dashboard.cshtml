@model PersonalProfileSystem.Mvc.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Profile Dashboard";
}

<div class="container my-5">

    <!-- Profile Header -->
        <div class="card shadow-sm rounded-3 mb-2 p-3">

                <!-- Scrollable Cover -->
            <div class="position-relative " style="height:300px;">

            <div class="rounded" style="height:300px; overflow-y:auto;">
                    <img src="~/images/cover/cover.jpg" style="width:100%;">
                </div>

                <!-- Profile Image -->
                <button class="rounded-circle border-0 p-0 shadow position-absolute start-0 ms-4"
                        style="width:120px; height:120px; overflow:hidden; bottom:-60px; border:4px solid white;">
                    <img src="~/images/profile/sshree.jpg"
                         style="width:100%; height:100%; object-fit:cover;">
                </button>

            </div>

            <!-- Space for overlap -->
            <div style="height:70px;"></div>


            <div>
                <h3 class="fw-bold d-inline">@Model.Person.FirstName @Model.Person.MiddleName @Model.Person.LastName</h3>
                <button class="btn btn-primary float-end">Edit</button>
                <button class="btn btn-primary float-end mx-2">Add</button>
                <p class="text-muted mb-1">DOB: @Model.Person.Dob.ToShortDateString()</p>
                <p class="text-muted">Created: @Model.Person.CreatedDate.ToShortDateString()</p>
            </div>
            
        </div>

    <!-- Contact Info -->
    @if (Model.Contact != null)
    {
        <div class="card shadow-sm rounded-3 mb-2 p-3">
            <div>
                <h5 class="fw-bold d-inline">Contact Information</h5>
                <button class="btn btn-primary float-end">Edit</button>
                <button class="btn btn-primary float-end mx-2">Add</button>
            </div>
            <p><strong>Email:</strong> @Model.Contact.Email</p>
            <p><strong>Phone:</strong> @Model.Contact.Phone</p>
        </div>
    }

    <!-- Addresses -->
    @if (Model.Addresses != null && Model.Addresses.Any())
    {
        <div class="card shadow-sm rounded-3 mb-2 p-3">
            <div>
                <h5 class="fw-bold d-inline">Addresses</h5>
                <button class="btn btn-primary float-end">Edit</button>
                <button class="btn btn-primary float-end mx-2">Add</button>
            </div>

            <ul class="list-unstyled mb-0">
                @foreach (var ua in Model.Addresses)
                {
                    var addr = ua.Address;
                    <li>@addr.Tole, Ward @addr.Ward, @addr.DistrictCity, @addr.ProvinceState, @addr.Country</li>
                }
            </ul>
        </div>
    }

    <!-- Skills -->
    <div class="card shadow-sm rounded-3 mb-2 p-3">
        <div class="mb-2">
            <h5 class="fw-bold mb-3 d-inline">Skills</h5>
            <button class="btn btn-primary float-end">Edit</button>
            <button class="btn btn-primary float-end mx-2">Add</button>
        </div>
        <div class="row g-2">
            @foreach (var us in Model.Skills)
            {
                var skill = us.Skill;
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <div class="bg-primary text-white text-center p-1 rounded d-flex align-items-center justify-content-center" style="height: 40px;">
                        <span class="text-truncate" title="@($"{skill.SkillName} ({us.SkillLevel}) {us.YearsOfExperience}")">
                            @skill.SkillName (@us.SkillLevel)
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Education -->
    @if (Model.Educations != null && Model.Educations.Any())
    {
        <div class="card shadow-sm rounded-3 mb-2 p-3">
            <div class="mb-2">
                <h5 class="fw-bold d-inline">Education</h5>
                <button class="btn btn-primary float-end">Edit</button>
                <button class="btn btn-primary float-end mx-2">Add</button>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var ue in Model.Educations)
                {
                    var edu = ue.Education;
                    <li class="list-group-item">
                        <strong>@edu.Degree</strong> in @edu.Field <br />
                        @edu.InstitutionName, @edu.Location (@ue.PassedYear)
                    </li>
                }
            </ul>
        </div>
    }

</div>