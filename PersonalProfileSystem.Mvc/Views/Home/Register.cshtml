@model PersonalProfileSystem.Mvc.Models.PersonInfo

@{
    ViewData["Title"] = "Register";
}

<div class="container d-flex justify-content-center align-items-center vh-100">
    <div class="card shadow-lg p-4 rounded-4 w-100" style="max-width: 500px;">
        <h3 class="text-center mb-4 fw-bold">Create New Profile</h3>

        <form asp-action="Register" method="post" novalidate>
            <!-- Person fields -->
            <div class="mb-3">
                <label asp-for="FirstName" class="form-label">First Name</label>
                <input asp-for="FirstName" class="form-control form-control-lg" required />
                <span asp-validation-for="FirstName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MiddleName" class="form-label">Middle Name</label>
                <input asp-for="MiddleName" class="form-control form-control-lg" />
                <span asp-validation-for="MiddleName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LastName" class="form-label">Last Name</label>
                <input asp-for="LastName" class="form-control form-control-lg" required />
                <span asp-validation-for="LastName" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Dob" class="form-label">Date of Birth</label>
                <input asp-for="Dob" type="date" class="form-control form-control-lg" required />
                <span asp-validation-for="Dob" class="text-danger"></span>
            </div>

            <!-- Contact fields (manual input names) -->
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input name="Email" type="email" class="form-control form-control-lg" required />
            </div>

            <div class="mb-3">
                <label class="form-label">Phone</label>
                <input name="Phone" type="text" class="form-control form-control-lg" required />
            </div>

            <div class="d-grid mt-3">
                <button type="submit" class="btn btn-success btn-lg rounded-pill">Create Profile</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}