@model PersonalProfileSystem.Mvc.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Profile Dashboard";
}

<div class="container my-3">
            <div class="position-relative " style="height:300px;">
                <img class="rounded-top-4" src="~/images/cover/Cover.jpg" style="width:100%; height:100%; object-fit:cover;">
                <!-- Cover edit button -->
                <button class="btn btn-light position-absolute rounded-circle" style="top:20px; right:20px; z-index:10;"><i class="fa-regular fa-camera"></i></button>
            </div>
        <div class="card shadow-sm mb-2 p-3">


            <!-- Profile Image -->
            <button class="rounded-circle border-0 p-0 shadow position-relative start-0 ms-4"
                    style="width:120px; height:120px; overflow:hidden; margin-top:-60px; border:4px solid white; z-index:5;">
                <img src="~/images/profile/sshree.jpg" style="width:100%; height:100%; object-fit:cover;">
            </button>


            <div>
                <h3 class="fw-bold d-inline">@Model.Person.FirstName @Model.Person.MiddleName @Model.Person.LastName</h3>
                <button class="btn btn-transparent float-end rounded-circle"><i class="fa-solid fa-pen-to-square"></i></button>
                <p class="text-muted mb-1">DOB: @Model.Person.Dob.ToShortDateString()</p>
                <p class="text-muted">Created: @Model.Person.CreatedDate.ToShortDateString()</p>
            </div>
    
        </div>

    <!-- Contact Info -->
    @if (Model.Contact != null)
    {
        <div class="card shadow-sm rounded-4 mb-2 p-3">
            <div>
                <h5 class="fw-bold d-inline">Contact Information</h5>
                <button class="btn btn-transparent float-end rounded-circle"><i class="fa-solid fa-pen-to-square"></i></button>
            </div>
            <p><strong>Email:</strong> @Model.Contact.Email</p>
            <p><strong>Phone:</strong> @Model.Contact.Phone</p>
        </div>
    }

    <!-- Addresses -->
    @if (Model.Addresses != null && Model.Addresses.Any())
    {
        <div class="card shadow-sm rounded-4 mb-2 p-3">




            <div>
                <h5 class="fw-bold d-inline">Addresses</h5>
                <button class="btn btn-transparent float-end rounded-circle"><i class="fa-solid fa-pen-to-square"></i></button>
                <button class="btn btn-transparent float-end rounded-circle mx-2"><i class="fa-solid fa-plus"></i></button>
            </div>

            <ul class="list-unstyled mb-0">
                @foreach (var ua in Model.Addresses)
                {
                    var addr = ua.Address;
                    <li>@addr.Tole, Ward @addr.Ward, @addr.DistrictCity, @addr.ProvinceState, @addr.Country</li>
                }
            </ul>
        </div>
    }

    <!-- Skills -->
    <div class="card shadow-sm rounded-4 mb-2 p-3">
        <div class="mb-2">
            <h5 class="fw-bold mb-3 d-inline">Skills</h5>
            <button class="btn btn-transparent float-end rounded-circle"><i class="fa-solid fa-pen-to-square"></i></button>
            <a href="#" class="btn btn-transparent float-end rounded-circle mx-2" data-bs-toggle="modal" data-bs-target="#addSkillModal">
                <i class="fa-solid fa-plus"></i>
            </a>
        </div>
        <div class="row g-2">
            @foreach (var us in Model.Skills)
            {
                var skill = us.Skill;
                <div class="col-6 col-sm-4 col-md-3 col-lg-2">
                    <div class="bg-primary text-white text-center p-2 rounded d-flex align-items-center justify-content-center" style="height: 40px;">
                        <span class="text-truncate" title="@($"{skill.SkillName} ({us.SkillLevel}) {us.YearsOfExperience}")">
                            @skill.SkillName (@us.SkillLevel)
                        </span>
                    </div>
                </div>
            }
        </div>
    </div>

    <!-- Education -->
    @if (Model.Educations != null && Model.Educations.Any())
    {
        <div class="card shadow-sm rounded-4 mb-2 p-3">
            <div class="mb-2">
                <h5 class="fw-bold d-inline">Education</h5>
                <button class="btn btn-transparent float-end rounded-circle"><i class="fa-solid fa-pen-to-square"></i></button>
                <button class="btn btn-transparent float-end rounded-circle mx-2"><i class="fa-solid fa-plus"></i></button>
            </div>
            <ul class="list-group list-group-flush">
                @foreach (var ue in Model.Educations)
                {
                    var edu = ue.Education;
                    <li class="list-group-item">
                        <strong>@edu.Degree</strong> in @edu.Field <br />
                        @edu.InstitutionName, @edu.Location (@(ue.PassedYear?.ToString() ?? "Present"))
                    </li>
                }
            </ul>
        </div>
    }

</div>




<!-- ===== Add Skill Modal ===== -->
<div class="modal fade" id="addSkillModal" tabindex="-1" aria-labelledby="addSkillModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <form asp-action="AddSkill" method="post" class="p-3">
                <!-- Hidden UserId -->
                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="addSkillModalLabel">Add New Skill</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Skill Name -->
                    <div class="mb-3">
                        <input name="SkillName" class="form-control form-control-lg" placeholder="Skill Name (e.g. C#)" required />
                    </div>

                    <!-- Skill Level -->
                    <div class="mb-3">
                        <select name="SkillLevel" class="form-select form-select-lg" required>
                            <option value="" disabled selected>Skill Level</option>
                            <option value="Beginner">Beginner</option>
                            <option value="Intermediate">Intermediate</option>
                            <option value="Advanced">Advanced</option>
                            <option value="Expert">Expert</option>
                        </select>
                    </div>

                    <!-- Years of Experience -->
                    <div class="mb-3">
                        <input name="YearsOfExperience" type="number" min="0" class="form-control form-control-lg" placeholder="Years of Experience" required />
                    </div>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Add Skill</button>
                </div>
            </form>

        </div>
    </div>
</div>