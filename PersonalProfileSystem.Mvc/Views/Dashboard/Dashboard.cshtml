@using PersonalProfileSystem.Mvc.Models
@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel;

@{
    ViewData["Title"] = "Profile Dashboard";
}

<div class="container my-3">
    <div class="position-relative" style="height:300px;">
        <img class="rounded-top-4" src="~/images/cover/Cover.jpg" style="width:100%; height:100%; object-fit:cover;">
            <!-- Cover edit button - just add these attributes -->
            <button class="btn btn-light position-absolute rounded-circle"
                    style="top:20px; right:20px; z-index:10;"
                    data-bs-toggle="modal"
                    data-bs-target="#updateCoverPicModal">
                <i class="fa-regular fa-camera"></i>
            </button>
        </div>

        <div class="card shadow-sm mb-2 p-3">
            <!-- Profile Image - just add these attributes -->
            <button class="rounded-circle border-0 p-0 shadow position-relative start-0 ms-4"
                    style="width:120px; height:120px; overflow:hidden; margin-top:-60px; border:4px solid white; z-index:5;"
                    data-bs-toggle="modal"
                    data-bs-target="#updateProfilePicModal">
                <img src="~/images/profile/sshree.jpg" style="width:100%; height:100%; object-fit:cover;">
                </button>
    
                <div>
                    <h3 class="fw-bold d-inline">@Model.Person.FirstName @Model.Person.MiddleName @Model.Person.LastName</h3>
                    <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#updateProfileModal">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </a>
                    <p class="text-muted mb-1">DOB: @Model.Person.Dob.ToShortDateString()</p>
                    <p class="text-muted">Created: @Model.Person.CreatedDate.ToShortDateString()</p>
                </div>
            </div>

    <!-- Contact Info -->
        <div class="card shadow-sm rounded-4 mb-2 p-3">
            <div>
                <h5 class="fw-bold d-inline"><i class="fa-solid fa-address-book" style="color: rgb(116, 192, 252);"></i> Contact Information</h5>
                    <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#updateSkmyodal">
                        <i class="fa-solid fa-pen-to-square"></i>
                    </a>
            </div>
            <p><strong>Email:</strong> @Model.Contact.Email</p>
            <p><strong>Phone:</strong> @Model.Contact.Phone</p>
        </div>

    <!-- Addresses -->
            <div class="card shadow-sm rounded-4 mb-2 p-3">
                <div>
                    <h5 class="fw-bold d-inline"><i class="fa-solid fa-location-arrow" style="color: rgb(99, 230, 190);"></i> Addresses</h5>
                    <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#addAddressModal">
                        <i class="fa-solid fa-plus"></i>
                    </a>
                </div>

                <ul class="list-unstyled mx-0">
                    @foreach (var ua in Model.Addresses)
                    {
                        var addr = ua.Address;
                        <li class="d-flex justify-content-between align-items-center mx-3">
                            <span>@addr.Tole, Ward @addr.Ward, @addr.DistrictCity, @addr.ProvinceState, @addr.Country</span>
                            <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#updateAddressModal">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                        </li>
                    }
                </ul>
            </div>

            <!-- Skills -->
            <div class="card shadow-sm rounded-4 mb-2 p-3">
                <div class="mb-2">
                    <h5 class="fw-bold mb-3 d-inline"><i class="fa-solid fa-star" style="color: rgb(255, 212, 59);"></i> Skills</h5>
                    <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#addSkillModal">
                        <i class="fa-solid fa-plus"></i>
                    </a>
                </div>

                <ul class="list-group list-group-flush">
                    @if (Model.Skills.Any())
                    {
                        foreach (var us in Model.Skills)
                        {
                            var skill = us.Skill;
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <div>
                                    <div>
                                        <strong>@skill.SkillName</strong>
                                        <span class="text-muted">(@us.SkillLevel)</span>
                                    </div>
                                    <div><small>@us.YearsOfExperience years of experience</small></div>
                                </div>
                                <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#updateSkillModal">
                                    <i class="fa-solid fa-pen-to-square"></i>
                                </a>
                            </li>
                        }
                    }
                    else
                    {
                        <li class="list-group-item text-muted">No skills added yet.</li>
                    }
                </ul>
            </div>

            <!-- Education -->
            <div class="card shadow-sm rounded-4 mb-2 p-3">
                <div class="mb-2">
                    <h5 class="fw-bold d-inline"><i class="fa-solid fa-graduation-cap"></i> Education</h5>
                    <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#addEducationModal">
                        <i class="fa-solid fa-plus"></i>
                    </a>
                </div>
                <ul class="list-group list-group-flush">
                    @foreach (var ue in Model.Educations)
                    {
                        var edu = ue.Education;
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <strong>@edu.Degree</strong> in @edu.Field <br />
                                @edu.InstitutionName, @edu.Location (@(ue.PassedYear?.ToString() ?? "Present"))
                            </div>
                            <a href="#" class="btn btn-transparent float-end rounded-circle" data-bs-toggle="modal" data-bs-target="#updateEducationModal">
                                <i class="fa-solid fa-pen-to-square"></i>
                            </a>
                         </li>
                    }
                </ul>
            </div>

        @await Html.PartialAsync("Modals/_UpdateProfilePicModal", Model)
        @await Html.PartialAsync("Modals/_UpdateCoverPicModal", Model)
        @await Html.PartialAsync("Modals/_UpdateProfileModal", Model)
        @await Html.PartialAsync("Modals/_UpdateContactModal", Model)
        @await Html.PartialAsync("Modals/_AddAddressModal", Model)
        @await Html.PartialAsync("Modals/_AddSkillModal", Model)
        @await Html.PartialAsync("Modals/_AddEducationModal", Model)
        @await Html.PartialAsync("Modals/_UpdateAddressModal", Model)
        @await Html.PartialAsync("Modals/_UpdateSkillModal", Model)
        @await Html.PartialAsync("Modals/_UpdateEducationModal", Model)

</div>




