@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<!-- Update Skill Modal -->
<div class="modal fade" id="updateSkillModal" tabindex="-1" aria-labelledby="updateSkillModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="p-3">
                <!-- Hidden fields for both forms -->
                <input type="hidden" id="updateSkillUserId" value="@Model.UserId" />
                <input type="hidden" id="updateSkillId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="updateSkillModalLabel">Update Skill</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Update Form -->
                    <form asp-action="UpdateSkill" method="post" id="updateSkillForm">
                        <input type="hidden" name="UserId" id="skillFormUserId" />
                        <input type="hidden" name="SkillId" id="skillFormSkillId" />

                        <!-- Skill Name -->
                        <div class="mb-3">
                            <input id="updateSkillName" name="SkillName" class="form-control form-control-lg"
                                   placeholder="Skill Name (e.g. C#)" required />
                        </div>

                        <!-- Skill Level -->
                        <div class="mb-3">
                            <select id="updateSkillLevel" name="SkillLevel" class="form-select form-select-lg" required>
                                <option value="" disabled>Skill Level</option>
                                <option value="Beginner">Beginner</option>
                                <option value="Intermediate">Intermediate</option>
                                <option value="Advanced">Advanced</option>
                                <option value="Expert">Expert</option>
                            </select>
                        </div>

                        <!-- Years of Experience -->
                        <div class="mb-3">
                            <input id="updateYearsOfExperience" name="YearsOfExperience" type="number" min="0"
                                   class="form-control form-control-lg" placeholder="Years of Experience" />
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="updateSkillForm" class="btn btn-primary rounded-pill px-4">Update Skill</button>
                    
                    <!-- Separate Delete Form -->
                    <form asp-action="DeleteSkill" method="post" id="deleteSkillForm" style="display: inline;">
                        <input type="hidden" name="UserId" id="deleteSkillUserId" />
                        <input type="hidden" name="SkillId" id="deleteSkillId" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4"
                                onclick="return confirm('Are you sure you want to delete this skill?')">
                            Delete
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
