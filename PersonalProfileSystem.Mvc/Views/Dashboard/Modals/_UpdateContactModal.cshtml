<div class="modal fade" id="updateContactModal" tabindex="-1" aria-labelledby="updateContactModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="p-3">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="updateContactModalLabel">Update Contact Information</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Update Form -->
                    <form asp-action="UpdateContact" asp-controller="Dashboard" method="post" id="updateContactForm">
                        @Html.AntiForgeryToken()   <!-- This is very important! -->

                        <input type="hidden" name="UserId" value="@Model.UserId" />
                        <input type="hidden" name="ContactId" value="@Model.Contact?.ContactId" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Email Address</label>
                            <input name="Email"
                                   value="@Model.Contact?.Email"
                                   type="email"
                                   class="form-control form-control-lg"
                                   placeholder="Enter email address"
                                   required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Phone Number</label>
                            <input name="Phone"
                                   value="@Model.Contact?.Phone"
                                   type="tel"
                                   class="form-control form-control-lg"
                                   placeholder="Enter phone number"
                                   required />
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="updateContactForm" class="btn btn-primary rounded-pill px-4">Update Contact</button>
                </div>
            </div>

        </div>
    </div>
</div>