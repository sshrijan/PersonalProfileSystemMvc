<!-- Update Cover Picture Modal -->
<div class="modal fade" id="updateCoverPicModal" tabindex="-1" aria-labelledby="updateCoverPicModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="p-3">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="updateCoverPicModalLabel">Update Cover Picture</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Update Form -->
                    <form asp-action="UpdateCoverPicture" method="post" enctype="multipart/form-data" id="updateCoverPicForm">
                        <input type="hidden" name="UserId" value="@Model.UserId" />

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Current Cover Picture</label>
                            <div class="text-center mb-3">
                                <img src="~/images/cover/Cover.jpg" id="currentCoverPic"
                                     style="width:100%; height:150px; object-fit:cover; border-radius:10px; border:1px solid #ddd;" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Upload New Cover Picture</label>
                            <input type="file" name="CoverPicture" class="form-control form-control-lg"
                                   accept="image/*" required />
                            <small class="text-muted">Supported formats: JPG, PNG, GIF (Max: 5MB). Recommended size: 1200x300px</small>
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="updateCoverPicForm" class="btn btn-primary rounded-pill px-4">Update Cover</button>
                </div>
            </div>

        </div>
    </div>
</div>