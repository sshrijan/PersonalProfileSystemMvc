@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<!-- Add Education Modal -->
<div class="modal fade" id="addEducationModal" tabindex="-1" aria-labelledby="addEducationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="p-3">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="addEducationModalLabel">Add Education</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <form asp-action="AddEducation" method="post" id="addEducationForm">
                        @Html.AntiForgeryToken()
                        
                        <input type="hidden" name="UserId" value="@Model.UserId" />

                        <div class="mb-3">
                            <input type="text" name="InstitutionName" class="form-control form-control-lg"
                                   placeholder="Institution Name" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" name="Degree" class="form-control form-control-lg"
                                   placeholder="Degree" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" name="Field" class="form-control form-control-lg"
                                   placeholder="Field of Study" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" name="Location" class="form-control form-control-lg"
                                   placeholder="Location" required />
                        </div>

                        <div class="form-check mb-3">
                            <input type="checkbox" class="form-check-input" id="addCurrentlyStudying" name="CurrentlyStudying" value="true" />
                            <input type="hidden" name="CurrentlyStudying" value="false" />
                            <label class="form-check-label" for="addCurrentlyStudying">
                                Currently Studying Here
                            </label>
                        </div>

                        <div class="mb-3">
                            <input type="number" id="addPassedYear" name="PassedYear" class="form-control form-control-lg"
                                   placeholder="Passed Year" />
                        </div>

                        <div class="mb-3">
                            <input type="text" id="addGrade" name="Grade" class="form-control form-control-lg"
                                   placeholder="Grade / GPA" />
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="addEducationForm" class="btn btn-primary rounded-pill px-4">Add Education</button>
                </div>
            </div>
        </div>
    </div>
</div>