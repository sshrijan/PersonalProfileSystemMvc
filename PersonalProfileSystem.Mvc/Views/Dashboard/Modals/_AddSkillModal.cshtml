@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<div class="modal fade" id="addSkillModal" tabindex="-1" aria-labelledby="addSkillModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <form asp-action="AddSkill" method="post" class="p-3">
                <!-- Hidden UserId -->
                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="addSkillModalLabel">Add New Skill</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Skill Name -->
                    <div class="mb-3">
                        <input name="SkillName" class="form-control form-control-lg" placeholder="Skill Name (e.g. C#)" required />
                    </div>

                    <!-- Skill Level -->
                    <div class="mb-3">
                        <select name="SkillLevel" class="form-select form-select-lg" required>
                            <option value="" disabled selected>Skill Level</option>
                            <option value="Beginner">Beginner</option>
                            <option value="Intermediate">Intermediate</option>
                            <option value="Advanced">Advanced</option>
                            <option value="Expert">Expert</option>
                        </select>
                    </div>

                    <!-- Years of Experience -->
                    <div class="mb-3">
                        <input name="YearsOfExperience" type="number" min="0" class="form-control form-control-lg" placeholder="Years of Experience" />
                    </div>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary rounded-pill px-4">Add Skill</button>
                </div>
            </form>

        </div>
    </div>
</div>