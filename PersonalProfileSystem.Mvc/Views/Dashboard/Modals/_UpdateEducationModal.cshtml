@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<!-- Update Education Modal -->
<div class="modal fade" id="updateEducationModal" tabindex="-1" aria-labelledby="updateEducationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="p-3">
                <!-- Hidden fields for both forms -->
                <input type="hidden" id="updateUserId" value="@Model.UserId" />
                <input type="hidden" id="updateEducationId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="updateEducationModalLabel">Update Education Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Update Form -->
                    <form asp-action="UpdateEducation" method="post" id="updateEducationForm">
                        <input type="hidden" name="UserId" id="formUserId" />
                        <input type="hidden" name="EducationId" id="formEducationId" />

                        <div class="mb-3">
                            <input id="updateInstitutionName" name="InstitutionName" class="form-control form-control-lg"
                                   placeholder="Institution Name (e.g., Tribhuvan University)" required />
                        </div>

                        <div class="mb-3">
                            <input id="updateDegree" name="Degree" class="form-control form-control-lg"
                                   placeholder="Degree (e.g., Bachelor's)" required />
                        </div>

                        <div class="mb-3">
                            <input id="updateField" name="Field" class="form-control form-control-lg"
                                   placeholder="Field of Study (e.g., Computer Science)" required />
                        </div>

                        <div class="mb-3">
                            <input id="updateLocation" name="Location" class="form-control form-control-lg"
                                   placeholder="Location (e.g., Kathmandu, Nepal)" required />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="updateCurrentlyStudying" name="CurrentlyStudying">
                            <label class="form-check-label">Currently Studying Here</label>
                        </div>

                        <div class="mb-3">
                            <input id="updatePassedYear" name="PassedYear" class="form-control form-control-lg"
                                   placeholder="Passed Year (e.g., 2024)">
                        </div>

                        <div class="mb-3">
                            <input id="updateGrade" name="Grade" class="form-control form-control-lg"
                                   placeholder="Grade / GPA (e.g., 3.8, A+, 85%)">
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="updateEducationForm" class="btn btn-primary rounded-pill px-4">Update Education</button>
                    
                    <!-- Separate Delete Form -->
                    <form asp-action="DeleteEducation" method="post" id="deleteEducationForm" style="display: inline;">
                        <input type="hidden" name="UserId" id="deleteUserId" />
                        <input type="hidden" name="EducationId" id="deleteEducationId" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4" onclick="return confirm('Are you sure you want to delete this education record?')">Delete</button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>

<script>
    // Populate function to fill the modal with education data
    function populateUpdateEducationModal(educationId, institutionName, degree, field, location, currentlyStudying, passedYear, grade, userId) {
        document.getElementById("formEducationId").value = educationId;
        document.getElementById("formUserId").value = userId;
        document.getElementById("updateInstitutionName").value = institutionName;
        document.getElementById("updateDegree").value = degree;
        document.getElementById("updateField").value = field;
        document.getElementById("updateLocation").value = location;
        
        // Set delete form values
        document.getElementById("deleteEducationId").value = educationId;
        document.getElementById("deleteUserId").value = userId;
        
        const currentlyStudyingCheckbox = document.getElementById("updateCurrentlyStudying");
        currentlyStudyingCheckbox.checked = currentlyStudying;
        
        if (currentlyStudying) {
            updatePassedYear.disabled = true;
            updateGrade.disabled = true;
            updatePassedYear.value = "";
            updateGrade.value = "";
        } else {
            updatePassedYear.disabled = false;
            updateGrade.disabled = false;
            updatePassedYear.value = passedYear;
            updateGrade.value = grade;
        }
    }
    
    // Handle Currently Studying checkbox functionality
    const updateCheckbox = document.getElementById("updateCurrentlyStudying");
    const updatePassedYear = document.getElementById("updatePassedYear");
    const updateGrade = document.getElementById("updateGrade");

    if (updateCheckbox) {
        updateCheckbox.addEventListener("change", function () {
            if (this.checked) {
                updatePassedYear.disabled = true;
                updateGrade.disabled = true;
                updatePassedYear.value = "";
                updateGrade.value = "";
            } else {
                updatePassedYear.disabled = false;
                updateGrade.disabled = false;
            }
        });
    }
</script>