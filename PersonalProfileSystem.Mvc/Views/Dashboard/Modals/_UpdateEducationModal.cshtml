@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<!-- Update Education Modal -->
<div class="modal fade" id="updateEducationModal" tabindex="-1" aria-labelledby="updateEducationModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="p-3">
                <!-- Hidden fields for both forms -->
                <input type="hidden" id="updateUserId" value="@Model.UserId" />
                <input type="hidden" id="updateEducationId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="updateEducationModalLabel">Update Education Details</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Update Form -->
                    <form asp-action="UpdateEducation" method="post" id="updateEducationForm">
                        <input type="hidden" name="UserId" id="formUserId" />
                        <input type="hidden" name="EducationId" id="formEducationId" />

                        <!-- Hidden fallback (IMPORTANT) -->
                        <input type="hidden" name="PassedYear" value="" />
                        <input type="hidden" name="Grade" value="" />

                        <div class="mb-3">
                            <input id="updateInstitutionName" name="InstitutionName" class="form-control form-control-lg" required />
                        </div>

                        <div class="mb-3">
                            <input id="updateDegree" name="Degree" class="form-control form-control-lg" required />
                        </div>

                        <div class="mb-3">
                            <input id="updateField" name="Field" class="form-control form-control-lg" required />
                        </div>

                        <div class="mb-3">
                            <input id="updateLocation" name="Location" class="form-control form-control-lg" required />
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="updateCurrentlyStudying" name="CurrentlyStudying">
                            <label class="form-check-label">Currently Studying Here</label>
                        </div>

                        <div class="mb-3">
                            <input id="updatePassedYear" name="PassedYear" class="form-control form-control-lg"
                                   placeholder="Passed Year (e.g., 2024)">
                        </div>

                        <div class="mb-3">
                            <input id="updateGrade" name="Grade" class="form-control form-control-lg"
                                   placeholder="Grade / GPA">
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="updateEducationForm" class="btn btn-primary rounded-pill px-4">Update Education</button>
                </div>
            </div>

        </div>
    </div>
</div>
