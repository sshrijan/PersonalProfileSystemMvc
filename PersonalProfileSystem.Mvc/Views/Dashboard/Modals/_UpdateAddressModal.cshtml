@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<!-- Update Address Modal -->
<div class="modal fade" id="updateAddressModal" tabindex="-1" aria-labelledby="updateAddressModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <div class="p-3">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold" id="updateAddressModalLabel">Update Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>

                <div class="modal-body pt-0">
                    <!-- Update Form -->
                    <form asp-action="UpdateAddress" method="post" id="updateAddressForm">
                        <input type="hidden" name="UserId" id="updateAddressUserId" />
                        <input type="hidden" name="AddressId" id="updateAddressId" />

                        <div class="mb-3">
                            <input type="text" id="updateCountry" name="Country" class="form-control form-control-lg"
                                   placeholder="Country" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" id="updateProvinceState" name="ProvinceState" class="form-control form-control-lg"
                                   placeholder="Province" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" id="updateDistrictCity" name="DistrictCity" class="form-control form-control-lg"
                                   placeholder="District/City" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" id="updateTole" name="Tole" class="form-control form-control-lg"
                                   placeholder="Tole" required />
                        </div>

                        <div class="mb-3">
                            <input type="text" id="updateWard" name="Ward" class="form-control form-control-lg"
                                   placeholder="Ward" required />
                        </div>
                    </form>
                </div>

                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-outline-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" form="updateAddressForm" class="btn btn-primary rounded-pill px-4">Update Address</button>
                    
                    <!-- Separate Delete Form -->
                    <form asp-action="DeleteAddress" method="post" id="deleteAddressForm" style="display: inline;">
                        <input type="hidden" name="UserId" id="deleteAddressUserId" />
                        <input type="hidden" name="AddressId" id="deleteAddressId" />
                        <button type="submit" class="btn btn-danger rounded-pill px-4"
                                onclick="return confirm('Are you sure you want to delete this address?')">
                            Delete
                        </button>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
