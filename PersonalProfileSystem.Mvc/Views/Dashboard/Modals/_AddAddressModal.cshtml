@using PersonalProfileSystem.Mvc.ViewModels
@model DashboardViewModel

<div class="modal fade" id="addAddressModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4">

            <form asp-action="AddAddress" method="post" class="p-3">
                <input type="hidden" name="UserId" value="@Model.UserId" />

                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-bold">Add New Address</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>

                <div class="modal-body pt-0">
                    <div class="mb-3">
                        <input name="Country" class="form-control form-control-lg" placeholder="Country" required />
                    </div>
                    <div class="mb-3">
                        <input name="ProvinceState" class="form-control form-control-lg" placeholder="Province" required />
                    </div>
                    <div class="mb-3">
                        <input name="DistrictCity" class="form-control form-control-lg" placeholder="District/City" required />
                    </div>
                    <div class="mb-3">
                        <input name="Tole" class="form-control form-control-lg" placeholder="Tole" required />
                    </div>
                    <div class="mb-3">
                        <input name="Ward" class="form-control form-control-lg" placeholder="Ward" required />
                    </div>
                </div>

                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Add Address</button>
                </div>
            </form>

        </div>
    </div>
</div>